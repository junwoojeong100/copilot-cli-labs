# ===== Microsoft Foundry 설정 =====
# Microsoft Foundry 프로젝트 엔드포인트
# 형식: https://<resource-name>.services.ai.azure.com/api/projects/<project-name>
PROJECT_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/your-project

# 배포된 채팅 모델 이름 (예: gpt-4o, gpt-4.1, gpt-5.4)
MODEL_DEPLOYMENT_NAME=gpt-5.4

# ===== 예제 06 (RAG) — Azure AI Search 연동 =====
# Azure AI Search 엔드포인트
SEARCH_SERVICE_ENDPOINT=https://your-search-service.search.windows.net

# RAG 인덱스 이름 (없으면 자동 생성)
SEARCH_INDEX_NAME=maf-lab-knowledge-v1

# 임베딩 호출용 Azure OpenAI 엔드포인트
# 형식: https://<resource-name>.cognitiveservices.azure.com/
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/

# 임베딩 모델 배포 이름 (예: text-embedding-3-large)
EMBEDDING_DEPLOYMENT_NAME=text-embedding-3-large

# Azure OpenAI API 버전
AZURE_OPENAI_API_VERSION=2024-10-21

# ===== 예제 06 변형 (Foundry IQ RAG) — 지식 베이스 + agentic retrieval =====
# 기존 하이브리드 예제와 충돌하지 않도록 별도 인덱스 이름을 사용합니다.
# (없으면 src/06_rag_agent_foundry_iq.py 첫 실행 시 자동 생성·시드)
SEARCH_INDEX_NAME_IQ=maf-lab-knowledge-iq-v1

# (선택) agentic 벡터화용 Azure OpenAI 리소스 URL.
# 일부 환경은 .openai.azure.com 형식을 요구합니다. 미설정 시 AZURE_OPENAI_ENDPOINT 사용.
# AZURE_OPENAI_RESOURCE_URL=https://your-resource.openai.azure.com/

# (선택) 질의 계획 추론 강도 (minimal/low/medium, 기본값: minimal)
# FOUNDRY_IQ_REASONING_EFFORT=minimal

# ===== (심화) Foundry Agent SDK v2 — Application Insights 추적 =====
# SDK v2 예제(src/foundry_sdk_v2/)의 분산 추적 활성화 여부 (기본값: true)
# 추적에는 App Insights 리소스 + 프로젝트의 AppInsights 연결이 필요합니다.
ENABLE_TRACING=true

# ===== Copilot CLI MCP 연동 — GitHub MCP 서버 인증 =====
# .copilot/mcp-config.json의 github 서버 블록에서 Bearer 토큰으로 사용됩니다.
# GitHub Personal Access Token (repo, issues, pull_requests 스코프)
# 발급: https://github.com/settings/tokens
# 필요 스코프: repo, read:org, read:discussion (최소)
# GITHUB_PERSONAL_ACCESS_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
